# 复制为 .env 后填写

# dashscope | openai | custom
IMAGE_PROVIDER=dashscope

# ---------- 通义万相 2.7 (阿里云百炼 / DashScope) ----------
# 文档: https://help.aliyun.com/zh/model-studio/wan-image-generation-and-editing-api-reference
DASHSCOPE_API_KEY=sk-xxxxxxxx

# 模型: wan2.7-image | wan2.7-image-pro
DASHSCOPE_MODEL=wan2.7-image

# 可选: 留空则按宽高自动选 1K/2K/4K；也可手动指定 1K / 2K / 4K
DASHSCOPE_SIZE=

# 可选: 一般不用改
# DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
DASHSCOPE_WATERMARK=false
DASHSCOPE_THINKING_MODE=true

# ---------- OpenAI DALL-E ----------
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=dall-e-3

# ---------- 自定义 HTTP 接口（IMAGE_PROVIDER=custom 时使用）----------
CUSTOM_API_URL=https://your-api.com/v1/images/generations
CUSTOM_API_KEY=your-key

# ---------- 语音识别 ASR（dashscope | openai）----------
ASR_PROVIDER=dashscope

# DashScope SenseVoice（用同一个 DASHSCOPE_API_KEY）
# 模型: sensevoice-v1 | paraformer-v2
DASHSCOPE_ASR_MODEL=sensevoice-v1
# 留空使用默认端点
# DASHSCOPE_ASR_API_URL=

# OpenAI Whisper（ASR_PROVIDER=openai 时使用）
OPENAI_ASR_MODEL=whisper-1

# 音频上传限制 (MB)
ASR_MAX_FILE_SIZE_MB=10

# 服务配置
HOST=0.0.0.0
PORT=8000
OUTPUT_DIR=./outputs

# 默认生图参数
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
